{
  "entities": {
    "Material": {
      "title": "Material",
      "description": "A school material like a PDF, Word document, or Canva link.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the material."
        },
        "title": {
          "type": "string",
          "description": "Title of the material."
        },
        "description": {
          "type": "string",
          "description": "Optional description of the material."
        },
        "type": {
          "type": "string",
          "enum": ["pdf", "word", "canva", "link", "drive", "other"],
          "description": "Type of the material."
        },
        "url": {
          "type": "string",
          "description": "Download URL or external link."
        },
        "authorId": {
          "type": "string",
          "description": "ID of the user who uploaded the material."
        },
        "authorName": {
          "type": "string",
          "description": "Name of the user who uploaded the material."
        },
        "authorPhotoUrl": {
          "type": "string",
          "description": "Profile picture URL of the author."
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Keywords or tags for the material."
        },
        "downloadCount": {
          "type": "integer",
          "description": "Number of times the material has been downloaded."
        },
        "createdAt": {
          "type": "timestamp",
          "description": "When the material was created."
        }
      },
      "required": ["title", "type", "url", "authorId", "authorName", "createdAt"]
    },
    "Folder": {
      "title": "Folder",
      "description": "A directory to organize materials. Can be nested.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "parentId": { "type": "string", "description": "Parent folder ID or null." },
        "isPublic": { "type": "boolean", "description": "Whether the folder is visible to everyone." },
        "createdAt": { "type": "timestamp" },
        "isDeleted": { "type": "boolean" },
        "deletedAt": { "type": "timestamp" }
      },
      "required": ["name", "authorId", "authorName", "isPublic", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "A user of the SchoolHub application.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "customColor": { "type": "string", "description": "Custom aura color hex." },
        "customBadge": { "type": "string", "description": "Custom badge text." },
        "unlockedBadges": { 
          "type": "array",
          "items": { "type": "string" },
          "description": "IDs of unlocked achievement badges."
        },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "Save": {
      "title": "Save",
      "description": "Represents a material saved by a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "materialId": { "type": "string" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["userId", "materialId", "createdAt"]
    }
  },
  "firestore": {
    "/materials/{materialId}": {
      "schema": {
        "$ref": "#/entities/Material"
      },
      "description": "Stores all school materials."
    },
    "/saves/{saveId}": {
      "schema": {
        "$ref": "#/entities/Save"
      },
      "description": "Tracks materials saved by users."
    },
    "/folders/{folderId}": {
      "schema": {
        "$ref": "#/entities/Folder"
      },
      "description": "Stores directories for organizing materials."
    },
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profiles and roles."
    }
  }
}
