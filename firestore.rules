rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: materials
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required, < 200 chars)
    //   - description: string (optional, < 2000 chars)
    //   - type: string (required, enum: 'pdf', 'word', 'canva', 'link', 'drive', 'other')
    //   - url: string (required, < 1MB)
    //   - authorId: string (required, immutable)
    //   - authorName: string (required, < 100 chars)
    //   - authorPhotoUrl: string (optional, < 1000 chars)
    //   - tags: list (optional, < 20 items)
    //   - downloadCount: int (required, >= 0)
    //   - createdAt: timestamp (required, immutable)
    //
    // Collection: users
    // Document ID: user UID
    // Fields:
    //   - uid: string (required, immutable)
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - photoURL: string (optional)
    //   - role: string (required, enum: 'admin', 'user')
    //   - createdAt: timestamp (required, immutable)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.authorId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        request.auth.token.email_verified == true &&
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
          request.auth.token.email == "sem.gk01@gmail.com");
    }
    
    function isValidUrl(url) {
      return url is string &&
        (url.matches("^https://.*") || url.matches("^http://.*") || url.matches("^data:.*"));
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    
    function isValidMaterialData(data) {
      let allowedFields = ['id', 'title', 'description', 'type', 'url', 'authorId', 'authorName', 'authorPhotoUrl', 'tags', 'downloadCount', 'folderId', 'createdAt', 'isDeleted', 'deletedAt'];
      let requiredFields = ['title', 'type', 'url', 'authorId', 'authorName', 'downloadCount', 'createdAt'];
      
      return data.keys().hasOnly(allowedFields) &&
             data.keys().hasAll(requiredFields) &&
             data.title is string && data.title.size() >= 1 && data.title.size() <= 200 &&
             (!('description' in data) || data.description == null || (data.description is string && data.description.size() <= 2000)) &&
             data.type in ['pdf', 'word', 'canva', 'link', 'drive', 'other'] &&
             isValidUrl(data.url) && data.url.size() <= 1000000 &&
             data.authorId is string && data.authorId.size() > 0 &&
             data.authorName is string && data.authorName.size() >= 1 && data.authorName.size() <= 100 &&
             (!('authorPhotoUrl' in data) || data.authorPhotoUrl == null || (data.authorPhotoUrl is string && data.authorPhotoUrl.size() <= 1000)) &&
             data.tags is list && data.tags.size() <= 20 &&
             data.downloadCount is int && data.downloadCount >= 0 &&
             (!('folderId' in data) || data.folderId == null || (data.folderId is string && data.folderId.size() <= 128)) &&
             data.createdAt is timestamp &&
             (!('isDeleted' in data) || data.isDeleted is bool) &&
             (!('deletedAt' in data) || data.deletedAt == null || data.deletedAt is timestamp);
    }

    function isValidFolderData(data) {
      let allowedFields = ['id', 'name', 'authorId', 'authorName', 'parentId', 'isPublic', 'createdAt', 'isDeleted', 'deletedAt'];
      let requiredFields = ['name', 'authorId', 'authorName', 'isPublic', 'createdAt'];
      
      return data.keys().hasOnly(allowedFields) &&
             data.keys().hasAll(requiredFields) &&
             data.name is string && data.name.size() >= 1 && data.name.size() <= 100 &&
             data.authorId is string && data.authorId.size() > 0 &&
             data.authorName is string && data.authorName.size() >= 1 && data.authorName.size() <= 100 &&
             (!('parentId' in data) || data.parentId == null || (data.parentId is string && data.parentId.size() <= 128)) &&
             data.isPublic is bool &&
             data.createdAt is timestamp &&
             (!('isDeleted' in data) || data.isDeleted is bool) &&
             (!('deletedAt' in data) || data.deletedAt == null || data.deletedAt is timestamp);
    }

    function isValidUserData(data) {
      let allowedFields = ['uid', 'email', 'displayName', 'photoURL', 'role', 'customColor', 'customBadge', 'unlockedBadges', 'createdAt'];
      let requiredFields = ['uid', 'email', 'role', 'createdAt'];
      
      return data.keys().hasOnly(allowedFields) &&
             data.keys().hasAll(requiredFields) &&
             data.uid is string && data.uid == request.auth.uid &&
             data.email is string &&
             (!('displayName' in data) || data.displayName == null || (data.displayName is string && data.displayName.size() <= 100)) &&
             (!('photoURL' in data) || data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 1000)) &&
             (!('customColor' in data) || data.customColor == null || (data.customColor is string && data.customColor.size() <= 20)) &&
             (!('customBadge' in data) || data.customBadge == null || (data.customBadge is string && data.customBadge.size() <= 20)) &&
             (!('unlockedBadges' in data) || data.unlockedBadges is list) &&
             data.role in ['admin', 'user'] &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /materials/{materialId} {
      allow read: if true;
      
      allow create: if isAuthenticated() && 
                      isValidMaterialData(request.resource.data) && 
                      request.resource.data.authorId == request.auth.uid &&
                      request.resource.data.downloadCount == 0 &&
                      request.resource.data.createdAt == request.time;
      
      allow update: if (
        // Case 1: Only incrementing downloadCount (allowed for everyone)
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['downloadCount']) &&
         request.resource.data.downloadCount == resource.data.downloadCount + 1)
      ) || (
        // Case 2: Owner or Admin updating the document (requires authentication)
        isAuthenticated() && (request.auth.uid == resource.data.authorId || isAdmin()) && (
          (isValidMaterialData(request.resource.data) &&
           request.resource.data.authorId == resource.data.authorId &&
           request.resource.data.createdAt == resource.data.createdAt) ||
          // Action: Trash/Restore
          (request.resource.data.diff(resource.data).affectedKeys().hasAny(['isDeleted', 'deletedAt']) &&
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isDeleted', 'deletedAt']) &&
           request.resource.data.isDeleted is bool)
        )
      );
                    
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.authorId || isAdmin());
    }

    match /folders/{folderId} {
      allow read: if resource.data.isPublic == true || (isAuthenticated() && request.auth.uid == resource.data.authorId) || isAdmin();
      
      allow create: if isAuthenticated() && 
                      isValidFolderData(request.resource.data) && 
                      request.resource.data.authorId == request.auth.uid &&
                      request.resource.data.createdAt == request.time;
      
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.authorId || isAdmin()) && (
        // Action: Generic Update (requires full validation)
        (isValidFolderData(request.resource.data) &&
         request.resource.data.authorId == resource.data.authorId &&
         request.resource.data.createdAt == resource.data.createdAt) ||
        // Action: Trash/Restore (be more lenient on structure if only toggling deletion)
        (request.resource.data.diff(resource.data).affectedKeys().hasAny(['isDeleted', 'deletedAt']) &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isDeleted', 'deletedAt']) &&
         request.resource.data.isDeleted is bool)
      );
      
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.authorId || isAdmin());
    }

    match /users/{userId} {
      allow read: if true;
      
      allow create: if isAuthenticated() && 
                      userId == request.auth.uid &&
                      isValidUserData(request.resource.data) &&
                      (request.resource.data.role == 'user' || isAdmin());
                      
      allow update: if isAuthenticated() && 
                      userId == request.auth.uid &&
                      isValidUserData(request.resource.data) &&
                      (request.resource.data.role == resource.data.role || isAdmin());
                      
      allow delete: if isAdmin();
    }

    match /saves/{saveId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated() && 
                      request.resource.data.userId == request.auth.uid &&
                      request.resource.data.materialId is string &&
                      request.resource.data.createdAt == request.time;
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
    }
  }
}
