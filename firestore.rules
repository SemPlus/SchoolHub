rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: materials
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required, < 100 chars)
    //   - description: string (optional, < 1000 chars)
    //   - type: string (required, enum: 'pdf', 'word', 'canva', 'link', 'other')
    //   - url: string (required, < 500 chars)
    //   - authorId: string (required, immutable)
    //   - authorName: string (required, < 50 chars)
    //   - createdAt: timestamp (required, immutable)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.authorId;
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    
    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }
    
    function isValidOptionalString(field, minLen, maxLen) {
      return !(field in request.resource.data) ||
             request.resource.data[field] == null ||
             (request.resource.data[field] is string &&
              request.resource.data[field].size() >= minLen &&
              request.resource.data[field].size() <= maxLen);
    }
    
    function isValidUrl(url) {
      return url is string &&
        (url.matches("^https://.*") || url.matches("^http://.*"));
    }
    
    function areImmutableFieldsUnchanged(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    
    function isValidMaterial() {
      let allowedFields = ['title', 'description', 'type', 'url', 'authorId', 'authorName', 'authorPhotoUrl', 'tags', 'downloadCount', 'createdAt'];
      let requiredFields = ['title', 'type', 'url', 'authorId', 'authorName', 'downloadCount', 'createdAt'];
      
      return hasOnlyAllowedFields(allowedFields) &&
             hasRequiredFields(requiredFields) &&
             validStringLength('title', 1, 200) &&
             isValidOptionalString('description', 0, 2000) &&
             request.resource.data.type in ['pdf', 'word', 'canva', 'link', 'other'] &&
             validStringLength('url', 1, 1000) &&
             isValidUrl(request.resource.data.url) &&
             request.resource.data.authorId == request.auth.uid &&
             validStringLength('authorName', 1, 100) &&
             isValidOptionalString('authorPhotoUrl', 0, 1000) &&
             request.resource.data.tags is list &&
             request.resource.data.downloadCount is int &&
             request.resource.data.downloadCount >= 0 &&
             request.resource.data.createdAt is timestamp;
    }

    match /materials/{materialId} {
      // Anyone authenticated can read materials
      allow read: if isAuthenticated();
      
      // Only authenticated users can create materials, and they must be valid
      allow create: if isAuthenticated() && isValidMaterial();
      
      // Allow anyone authenticated to increment downloadCount
      // Only the owner can update other fields
      allow update: if isAuthenticated() && (
        // Case 1: Only incrementing downloadCount
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['downloadCount']) &&
         request.resource.data.downloadCount == resource.data.downloadCount + 1) ||
        // Case 2: Owner updating the document
        (isDocOwner() && 
         isValidMaterial() &&
         areImmutableFieldsUnchanged(['authorId', 'createdAt']))
      );
                    
      // Only the owner can delete their material
      allow delete: if isAuthenticated() && isDocOwner();
    }
  }
}
